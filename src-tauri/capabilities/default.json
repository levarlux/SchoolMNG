{
  "identifier": "default",
  "description": "Default capabilities for the SchoolMNG app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "dialog:default",
    "clerk:default",
    "store:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://*"
        }
      ]
    }
  ]
}